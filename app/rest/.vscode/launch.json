  "version": "0.2.0",
  "configurations": [
    {
      "request": "launch",
      "name": "Launch Program",
      "type": "node",
      "program": "${workspaceFolder}/main.ts",
      "cwd": "${workspaceFolder}",
      "env": {},
      "runtimeExecutable": "/home/nik/.deno/bin/deno",
      "runtimeArgs": [
        "run",
        "--inspect-wait",
        "-ENW",
        "--watch-hmr",
        "--unstable-kv",
        "--unstable-cron"
      ],
      "console": "integratedTerminal",
      "attachSimplePort": 9229
    }
  ]
}
