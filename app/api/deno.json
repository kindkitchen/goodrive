{
    "tasks": {
        "install": "deno install --allow-scripts",
        "dev": "deno run --allow-all src/main.app.api.ts --watch-hmr"
    },
    "imports": {
        "@elysiajs/node": "npm:@elysiajs/node@^1.3.0",
        "@elysiajs/swagger": "npm:@elysiajs/swagger@^1.3.0",
        "elysia": "npm:elysia@^1.3.5"
    },
    "nodeModulesDir": "auto",
    "unstable": [
        "kv",
        "cron",
        "temporal",
        "sloppy-imports",
        "fmt-sql",
        "fmt-component"
    ],
    "fmt": {
        "indentWidth": 4
    },
    "version": "0.10.0",
    "compilerOptions": {
        "strict": true
    }
}
